-- Logic: Advanced KO Detection
local function isTargetAlive(target)
    if not target or not target.Character then return false end
    local char = target.Character
    local hum = char:FindFirstChildOfClass("Humanoid")
    
    if not hum or hum.Health <= 0 or hum:GetState() == Enum.HumanoidStateType.Dead then return false end
    if char:GetAttribute("Knocked") == true or char:FindFirstChild("BodyEffects") and char.BodyEffects:FindFirstChild("Knocked") then
        return false 
    end
    return true
end

-- Logic: Target Finder
local function getTarget(str)
    for _, v in pairs(Players:GetPlayers()) do
        if v.Name:lower():find(str:lower()) or v.DisplayName:lower():find(str:lower()) then
            return v
        end
    end
end

-- Button Events
local styles = {"Orbit", "Wallbang", "Jitter"}
local sIdx = 1
StyleBtn.MouseButton1Click:Connect(function()
    sIdx = sIdx % #styles + 1
    SniperConfig.Style = styles[sIdx]
    StyleBtn.Text = "Style: " .. SniperConfig.Style
end)

Toggle.MouseButton1Click:Connect(function()
    SniperConfig.Enabled = not SniperConfig.Enabled
    if SniperConfig.Enabled then
        SniperConfig.Target = getTarget(Input.Text)
        Toggle.Text = "STOPPING..."
        Toggle.BackgroundColor3 = Color3.fromRGB(200, 50, 50)
    else
        Toggle.Text = "START LOCK"
        Toggle.BackgroundColor3 = Color3.fromRGB(0, 200, 100)
    end
end)

-- Runtime Loop
RunService.RenderStepped:Connect(function()
    if SniperConfig.Enabled and SniperConfig.Target then
        local tPlayer = SniperConfig.Target
        if isTargetAlive(tPlayer) then
            local root = tPlayer.Character:FindFirstChild("HumanoidRootPart")
            local myRoot = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
            
            if root and myRoot then
                local t = tick() * SniperConfig.Speed
                local pos
                
                if SniperConfig.Style == "Orbit" then
                    pos = root.Position + Vector3.new(math.cos(t) * SniperConfig.Distance, 1.5, math.sin(t) * SniperConfig.Distance)
                elseif SniperConfig.Style == "Wallbang" then
                    local side = math.sin(t*3) > 0 and 1 or -1
                    pos = (root.CFrame * CFrame.new(0, 0, SniperConfig.Distance * side)).Position
                elseif SniperConfig.Style == "Jitter" then
                    pos = root.Position + Vector3.new(math.random(-7,7), math.random(0,5), math.random(-7,7))
                end
                
                myRoot.CFrame = CFrame.new(pos, root.Position)
                myRoot.Velocity = Vector3.new(0,0,0)
            end
        end
    end
end)
